# Flask configuration
FLASK_ENV=development
SECRET_KEY=change_this_to_a_secure_random_string_for_production

# Database configuration
# For local testing, if DATABASE_URL is not set, a local SQLite database (teste_local.db) will be used automatically.
DATABASE_URL=postgresql://user:password@host:port/database

# Google OAuth 2.0 Configuration
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# For local testing, use: http://localhost:5001/login/google/callback
# For Render production, use: https://your-app-name.onrender.com/login/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5001/login/google/callback

# Access Control
# E-mail address allowed to access the dashboard and receive diários PDFs
PROFESSOR_EMAIL=rhormidas@gmail.com
ADMIN_PASSWORD=ori_admin_2026

# SMTP Configuration (For sending diário PDFs to the professor)
# Suggested providers: Gmail (with App Password), Resend, SendGrid, etc.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seu-sistema-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app-gmail
MAIL_DEFAULT_SENDER=seu-sistema-email@gmail.com

# Pix Donation Configuration
PIX_KEY=seu-email-ou-chave-pix@provedor.com
PIX_COPIA_COLA=
