# Flask configuration
FLASK_ENV=development
SECRET_KEY=change_this_to_a_secure_random_string_for_production

# Database configuration
# For local testing, if DATABASE_URL is not set, a local SQLite database (awo_ori.db) will be used automatically.
# In production (Render), set this variable to your external PostgreSQL database URL.
DATABASE_URL=postgresql://user:password@host:port/database
