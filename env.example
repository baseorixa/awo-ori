# Flask configuration
FLASK_ENV=development
SECRET_KEY=change_this_to_a_secure_random_string_for_production

# Database configuration
# For local testing, if DATABASE_URL is not set, a local SQLite database (teste_local.db) will be used automatically.
DATABASE_URL=postgresql://user:password@host:port/database

# Google OAuth 2.0 Configuration
# Create these credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# For local testing, use: http://localhost:5001/login/google/callback
# For Render production, use: https://your-app-name.onrender.com/login/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5001/login/google/callback

# Access Control
# Only Google users with this exact email will be allowed to access /dashboard, edit, or delete logs.
PROFESSOR_EMAIL=professor@example.com
